#
# Runtime artifacts from launch_*.sh / bench_ttft.sh -- not for version control.

# sed-substituted runtime YAMLs produced by launch_*.sh
configs/.runtime_*.yaml

# Server logs, PID files, KV transceiver csvs (regenerated each run)
logs/

# Benchmark output (regenerated each run); keep the FINDINGS.md analyses
results/**/*.bench.log
results/**/*.json
results/**/*-perf_metrics-time_diagram.html

# RWLT raw trajectory replay (1-2 MB per run; not needed for re-analysis --
# rwlt_requests.jsonl already has the per-turn metrics we use).
rwlt-results/**/openai_*phase*.jsonl
# RWLT client stdout, regenerable on rerun.
rwlt-results/**/*.rwlt.log
