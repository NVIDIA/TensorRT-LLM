# CBTS runtime config template, substituted by make_coveragerc.sh (or inline sed in the pipeline).
# Only [run] source and data_file are consumed by sitecustomize.py's PY_START tracker:
#   source    -> product roots to attribute (functions outside these are ignored)
#   data_file -> <dir>/.coverage.<stage>; the tracker writes .cbtscov.<stage>.<suffix>.json into <dir>

[run]
source =
    @TRTLLM_WHEEL_PATH@/tensorrt_llm/
data_file = @JOB_WORKSPACE@/.coverage.@STAGE_NAME@
