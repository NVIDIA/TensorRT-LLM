    {
      "type": "text",
      "id": "r1_data_t",
      "x": 500, "y": 180, "width": 330, "height": 124,
      "text": "request.py_multimodal_data = {\n \"multimodal_embedding_lengths\": [...],\n \"multimodal_encoder_item_metadata\":\n  MultimodalEncoderItemMetadata(\n   item_refs=[(\"image\",0),(\"video\",1)],\n   encoder_token_lengths=[...],\n   output_embedding_lengths=[...]),\n}",
