  {
   "type": "text",
   "id": "adm_startup_t",
   "x": 916,
   "y": 198,
   "width": 610,
   "height": 60,
   "text": "supports = isinstance(model, MultimodalModelMixin) AND processor capability\neffective tokens = max(configured or LLM fallback, model atomic maximum)\ncapacity \u2192 Q2.5: processor geometry; Q3: tokens/merge; Pixtral: min(items,tokens/merge)\nprofiling \u2192 sequential long-item + many-item boundaries within effective budget",
   "originalText": "supports = isinstance(model, MultimodalModelMixin) AND processor capability\neffective tokens = max(configured or LLM fallback, model atomic maximum)\ncapacity \u2192 Q2.5: processor geometry; Q3: tokens/merge; Pixtral: min(items,tokens/merge)\nprofiling \u2192 sequential long-item + many-item boundaries within effective budget",
   "fontSize": 11,
